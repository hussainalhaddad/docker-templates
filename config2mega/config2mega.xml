<?xml version="1.0"?>
<Container version="2">
  <Name>Config2Mega</Name>
  <Repository>hussainalhaddad/config2mega</Repository>
  <Registry>https://hub.docker.com/repository/docker/hussainalhaddad/config2mega</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/hussainalhaddad/docker-templates/tree/master/config2mega</Support>
  <Project>https://mega.nz/</Project>
  <Overview>Keep your Unraid configuration files synced with Mega.nz</Overview>
  <Category>Backup: Cloud:</Category>
  <WebUI/>
  <TemplateURL/>
  <Icon>https://github.com/hussainalhaddad/docker-templates/blob/master/config2mega/icon.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled>1615449119</DateInstalled>
  <DonateText>If you like my work please consider donating.</DonateText>
  <DonateLink>https://www.paypal.me/husainalhadad</DonateLink>
  <Description>Keep your Unraid configuration files synced with Mega.nz</Description>
  <Networking>
    <Mode>bridge</Mode>
    <Publish/>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/boot/config/</HostDir>
      <ContainerDir>/home/unraidconfig</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/appdata/Config2Mega/config</HostDir>
      <ContainerDir>/root/.megaCmd</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Environment>
    <Variable>
      <Value/>
      <Name>LOGIN</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value/>
      <Name>PASS</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value>unraid/boot/config</Value>
      <Name>REMOTE</Name>
      <Mode/>
    </Variable>
  </Environment>
  <Labels/>
  <Config Name="Email" Target="LOGIN" Default="" Mode="" Description="Container Variable: LOGIN" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="Password" Target="PASS" Default="" Mode="" Description="Container Variable: PASS" Type="Variable" Display="always" Required="true" Mask="true"/>
  <Config Name="Remote Folder" Target="REMOTE" Default="unraid/boot/config" Mode="" Description="Container Variable: REMOTE" Type="Variable" Display="always" Required="true" Mask="false">unraid/boot/config</Config>
  <Config Name="Unraid Config Folder" Target="/home/unraidconfig" Default="/boot/config/" Mode="rw" Description="Container Path: /home/unraidconfig" Type="Path" Display="advanced" Required="true" Mask="false">/boot/config/</Config>
  <Config Name="Mega config folder" Target="/root/.megaCmd" Default="/mnt/user/appdata/Config2Mega/config" Mode="rw" Description="Container Path: /root/.megaCmd" Type="Path" Display="advanced" Required="false" Mask="false">/mnt/user/appdata/Config2Mega/config</Config>
</Container>